# .env

# Node Environment (development or production)
NODE_ENV=development

# MongoDB Root Credentials
MONGO_ROOT_USER=Shane      # 替换为你想要的 MongoDB 用户名
MONGO_ROOT_PASS=Shane123456 # 替换为你想要的 MongoDB 强密码

# MongoDB Connection String (using service name 'mongo' and credentials)
# 替换 'your_database_name' 为你的实际数据库名称
MONGODB_URI=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASS}@mongo:27017/twitch_clone

# JWT Secret Key
JWT_SECRET=your_very_secure_and_long_jwt_secret_key # 替换为一个非常安全的密钥

# 如果你的后端还需要其他环境变量，也在这里添加
